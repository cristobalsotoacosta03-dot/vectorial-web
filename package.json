{
  "name": "vectorial-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:app": "npm run dev --workspace=apps/vectorial-app",
    "dev:web": "npm run dev --workspace=apps/vectorial-web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
